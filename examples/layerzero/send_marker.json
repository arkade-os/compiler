  "source": "\noptions {\n  server = server;\n  exit = exit;\n}\n\ncontract SendMarker(\n  bytes32 endpointSendScriptHash,\n  bytes32 endpointCtrlAssetId,\n  int     exit\n) {\n  function consume() {\n    require(this.activeInputIndex == 1, \"marker input position\");\n\n    require(\n      tx.inputs[0].arkadeScriptHash == endpointSendScriptHash,\n      \"endpoint state not via send closure\"\n    );\n\n    require(\n      tx.inputs[0].assets.lookup(endpointCtrlAssetId) == 1,\n      \"endpoint state input missing control asset\"\n    );\n  }\n}",
