  "source": "\noptions {\n  server = server;\n  exit = exit;\n}\n\ncontract ProviderShare(\n  pubkey providerPk,\n  int    depositedSats,\n  int    entryIndex,\n  int    exit\n) {\n\n  function redeem(signature providerSig) {\n    require(checkSig(providerSig, providerPk), \"invalid provider sig\");\n  }\n}",
